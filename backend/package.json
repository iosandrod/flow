{
  "name": "flowable-backend",
  "version": "1.0.0",
  "description": "工作流审批引擎 - 支持BPMN流程、Zeebe引擎、动态任务分配",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start": "node dist/app.js",
    "dev": "ts-node src/app.ts",
    "debug": "node --inspect=9229 -r ts-node/register src/app.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "workflow",
    "bpmn",
    "approval",
    "zeebe",
    "process-engine",
    "审批流程"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "body-parser": "^1.20.2",
    "bpmn-engine": "^25.0.1",
    "bpmn-moddle": "^10.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "mssql": "^12.2.0",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.1.13",
    "socket.io": "^4.7.2",
    "typeorm": "^0.3.17",
    "uuid": "^9.0.0",
    "zeebe-node": "^8.3.2"
  },
  "devDependencies": {
    "@types/bpmn-moddle": "^10.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "typeorm": ">=0.3.0"
  },
  "peerDependenciesMeta": {
    "typeorm": {
      "optional": true
    }
  }
}
